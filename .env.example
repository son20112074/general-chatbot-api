# API settings
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
BASE_URL=http://localhost:8000

# Connection settings
REDIS_URL=redis://localhost:6379
MQTT_BROKER_URL=mqtt://localhost:1883
WEBSOCKET_URL=ws://localhost:8080
SOCKET_URL=tcp://localhost:5000

# PaddleOCR-VL (image OCR): optional vLLM server URL to avoid local GPU/CUDA
# Example: https://6780-118-70-233-92.ngrok-free.app or https://your-server.com/v1
# PADDLEOCR_VL_SERVER_URL=https://6780-118-70-233-92.ngrok-free.app

# Logging
LOG_LEVEL=INFO

# Database settings
DATABASE_URI=postgresql+asyncpg://postgres:123456@localhost:5433/tms
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10